@page "/"
@inject Csla.ApplicationContext ApplicationContext
@using SPC.Infrastructure.TvanSubmission

<PageTitle>Tổng quan PIT</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="2" Class="mb-4">
    <MudText Typo="Typo.h4">Tổng quan</MudText>
    <MudChip T="string" Size="Size.Small" Color="@(_provider.IsAvailable ? Color.Primary : Color.Warning)"
             Icon="@Icons.Material.Filled.Cable">
        Nhà cung cấp: @_provider.DisplayName
    </MudChip>
</MudStack>

@if (_certs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.body2" Class="mb-2">@PrimaryWorkflowTitle</MudText>
    <div class="pit-dashboard-grid">
        @foreach (var card in PrimaryWorkflowCards)
        {
            var count = CountByStatus(card.Statuses);
            <MudPaper Class="pa-4 pit-dashboard-card" Elevation="2">
                <MudStack Class="fill-height" Justify="Justify.SpaceBetween">
                    <div>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                            <MudIcon Icon="@card.Icon" Color="@card.Color" Size="Size.Small" />
                            <MudText Typo="Typo.caption">@card.Title</MudText>
                        </MudStack>
                        <MudText Typo="Typo.h4">@count</MudText>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(card.Description))
                    {
                        <MudText Typo="Typo.caption">@card.Description</MudText>
                    }
                </MudStack>
            </MudPaper>
        }
    </div>

    <MudDivider Class="my-4" />

    <MudStack Row="true" Spacing="2">
        <MudButton Href="/pit/import" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload">Nhập Excel</MudButton>
        <MudButton Href="/pit/certificates" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Description">Xem chứng từ</MudButton>
        <MudButton Href="/pit/settings" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings">Cài đặt</MudButton>
    </MudStack>
}

<style>
    .pit-dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        align-items: stretch;
    }

    .pit-dashboard-card {
        height: 100%;
        min-height: 150px;
    }

    .pit-dashboard-card .fill-height {
        height: 100%;
    }

    @@media (max-width: 600px) {
        .pit-dashboard-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private PitCertificateInfoList? _certs;
    private TvanProviderInfo _provider = TvanProviderCatalog.Stub;

    private sealed record DashboardCard(
        string Title,
        IReadOnlyList<string> Statuses,
        Color Color,
        string Icon,
        string? Description = null);

    protected override async Task OnInitializedAsync()
    {
        var settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
        _provider = TvanProviderCatalog.Get(settings.TvanProviderName);
        _certs = await PitCertificateInfoList.GetAllAsync(ApplicationContext);
    }

    private string PrimaryWorkflowTitle =>
        _provider.Code switch
        {
            TvanProviderCatalog.NoneCode => "Quy trình lưu nội bộ. Chức năng nộp dữ liệu đang bị tắt trong cấu hình hiện tại.",
            _ when _provider.RequiresSignedXml => $"Quy trình {_provider.DisplayName}: tạo XML, ký số, gửi nộp và chờ phản hồi từ cơ quan thuế.",
            _ => $"Quy trình {_provider.DisplayName}: gửi thẳng đến nhà cung cấp và chờ phản hồi từ cơ quan thuế."
        };

    private IReadOnlyList<DashboardCard> PrimaryWorkflowCards =>
        _provider.Code switch
        {
            TvanProviderCatalog.NoneCode =>
            [
                new("Nháp", [CertificateStatus.Draft], Color.Default, Icons.Material.Filled.EditNote, "Dữ liệu mới chỉ được lưu trong hệ thống nội bộ."),
                new("Đã gửi", [CertificateStatus.Submitted], Color.Warning, Icons.Material.Filled.Send, "Dữ liệu lịch sử đang xử lý từ cấu hình hoặc nhà cung cấp trước đó."),
                new("Chấp nhận", [CertificateStatus.Accepted], Color.Success, Icons.Material.Filled.Verified, "Dòng đã khóa do đã có mã CQT."),
                new("Từ chối", [CertificateStatus.Rejected], Color.Error, Icons.Material.Filled.Error, "Dòng gửi trước đây bị từ chối.")
            ],
            _ when _provider.RequiresSignedXml =>
            [
                new("Nháp", [CertificateStatus.Draft], Color.Default, Icons.Material.Filled.EditNote),
                new("Đã tạo XML", [CertificateStatus.XmlGenerated], Color.Info, Icons.Material.Filled.DataObject),
                new("Đã ký", [CertificateStatus.Signed], Color.Warning, Icons.Material.Filled.Fingerprint),
                new("Đã gửi", [CertificateStatus.Submitted], Color.Warning, Icons.Material.Filled.Send),
                new("Chấp nhận", [CertificateStatus.Accepted], Color.Success, Icons.Material.Filled.Verified),
                new("Từ chối", [CertificateStatus.Rejected], Color.Error, Icons.Material.Filled.Error)
            ],
            _ =>
            [
                new("Nháp", [CertificateStatus.Draft], Color.Default, Icons.Material.Filled.EditNote),
                new("Đã gửi", [CertificateStatus.Submitted], Color.Warning, Icons.Material.Filled.Send, "Đã gửi cho nhà cung cấp mà không cần ký XML tại máy."),
                new("Chấp nhận", [CertificateStatus.Accepted], Color.Success, Icons.Material.Filled.Verified, "Cơ quan thuế đã trả về mã CQT."),
                new("Từ chối", [CertificateStatus.Rejected], Color.Error, Icons.Material.Filled.Error)
            ]
        };

    private int CountByStatus(IEnumerable<string> statuses) =>
        _certs?.Count(c => statuses.Contains(c.Status)) ?? 0;
}
