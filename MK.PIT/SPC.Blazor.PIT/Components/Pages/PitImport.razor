@page "/pit/import"
@inject Csla.ApplicationContext ApplicationContext
@inject PitExcelImporter Importer
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Nhập Excel PIT</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Nhập nhân viên từ Excel</MudText>

<MudExpansionPanels Elevation="0" Class="mb-4">
    <MudExpansionPanel Text="Yêu cầu tệp" Icon="@Icons.Material.Filled.Info">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Tệp và worksheet</MudText>
                <MudList T="string" Dense="true" DisablePadding="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.InsertDriveFile">
                        <MudText Typo="Typo.body2">Định dạng <b>.xlsx</b>, tối đa <b>10 MB</b></MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.TableChart">
                        <MudText Typo="Typo.body2">Tên sheet phải đúng chính xác là <code>Import form</code></MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.TableRows">
                        <MudText Typo="Typo.body2">Dòng 5 = tên trường chuẩn của hệ thống. Dòng 1-4 có thể dùng cho tiêu đề hiển thị.</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Numbers">
                        <MudText Typo="Typo.body2">Từ dòng 6 trở đi = dữ liệu nhân viên. Dòng trống sẽ được bỏ qua.</MudText>
                    </MudListItem>
                </MudList>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Cột bắt buộc (dòng 5)</MudText>
                <div>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">ProformaNo</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">TaxPayerTaxCode</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">TaxPayerName</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">IncomePaymentYear</MudChip>
                </div>
                <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2">Cột tùy chọn</MudText>
                <div>
                    @foreach (var opt in _optionalHeaders)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@opt</MudChip>
                    }
                </div>
                <MudText Typo="Typo.caption" Class="mt-2 d-block">Các cột không xác định sẽ bị bỏ qua.</MudText>
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Quy tắc trên từng dòng</MudText>
                <MudList T="string" Dense="true" DisablePadding="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircleOutline">
                        <MudText Typo="Typo.body2"><code>TaxPayerTaxCode</code> phải có <b>đúng 10 hoặc 13 chữ số</b> (chỉ gồm số).</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircleOutline">
                        <MudText Typo="Typo.body2"><code>IncomePaymentMonthFrom</code> phải &lt;= <code>IncomePaymentMonthTo</code> nếu cả hai đều có giá trị.</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircleOutline">
                        <MudText Typo="Typo.body2">Số tiền: dùng định dạng số chuẩn, không có dấu phân cách hàng nghìn (ô số của Excel vẫn hợp lệ).</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircleOutline">
                        <MudText Typo="Typo.body2">Ngày tháng: ưu tiên ô ngày của Excel (chuỗi ISO hoặc chuỗi hợp lệ vẫn được chấp nhận).</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.SwapHoriz">
                        <MudText Typo="Typo.body2">Chứng từ thay thế: điền <code>RelatedProformaNo</code> (và có thể thêm <code>RelatedFormNo</code>).</MudText>
                    </MudListItem>
                </MudList>
            </MudItem>

            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Href="samples/epit-sample-valid.xlsx" Target="_blank"
                               Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Download">
                        Tải tệp mẫu hợp lệ
                    </MudButton>
                    <MudButton Href="samples/epit-sample-with-errors.xlsx" Target="_blank"
                               Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Download">
                        Tệp mẫu có lỗi
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
        <InputFile id="xlsxInput" OnChange="OnInputFileChange" accept=".xlsx" hidden />
        <MudButton HtmlTag="label" for="xlsxInput" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload">
            Chọn tệp .xlsx
        </MudButton>
        @if (_fileName is not null)
        {
            <MudText Typo="Typo.body2">@_fileName (@_fileSize bytes)</MudText>
        }
    </MudStack>
</MudPaper>

@if (_result is not null)
{
    <MudAlert Severity="@(_result.HasErrors ? Severity.Error : Severity.Success)" Class="mb-3">
        Đã đọc @_result.Rows.Count dòng. Lỗi: @_result.ErrorCount. Cảnh báo: @_result.WarningCount.
    </MudAlert>

    @if (_result.Diagnostics.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Chẩn đoán</MudText>
        <MudSimpleTable Dense="true" Hover="true" Class="mb-4">
            <thead><tr><th>Ô</th><th>Dòng</th><th>Cột</th><th>Trường</th><th>Mức độ</th><th>Thông báo</th></tr></thead>
            <tbody>
            @foreach (var d in _result.Diagnostics)
            {
                <tr>
                    <td><strong>@d.CellRef</strong></td>
                    <td>@d.RowNumber</td>
                    <td>@d.ColumnLetter@(d.ColumnNumber.HasValue ? $" ({d.ColumnNumber})" : "")</td>
                    <td>@d.Field</td>
                    <td>@d.Severity</td>
                    <td>@d.Message</td>
                </tr>
            }
            </tbody>
        </MudSimpleTable>
    }

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_result.HasErrors || _committing)"
                   OnClick="CommitAsync">
            @(_committing ? "Đang nhập..." : $"Nhập {_result.Rows.Count} dòng")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Reset">Xóa</MudButton>
    </MudStack>
}

@code {
    private string? _fileName;
    private long _fileSize;
    private PitImportResult? _result;
    private bool _committing;

    private static readonly string[] _optionalHeaders =
    [
        "TaxPayerCode", "Nationality", "ResidentType", "IdentificationNo",
        "IssueDate", "IssuePlace", "Phone", "Email", "Address",
        "InsurancePremiums", "CharityDonations",
        "IncomePaymentMonthFrom", "IncomePaymentMonthTo",
        "TotalTaxableIncome", "AmountPersonalIncomeTax",
        "IncomeStillReceivable", "IncomeType", "Note",
        "RelatedProformaNo", "RelatedFormNo"
    ];

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        _fileName = file.Name;
        _fileSize = file.Size;
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        _result = Importer.Parse(ms);
    }

    private async Task CommitAsync()
    {
        if (_result is null || _result.HasErrors) return;
        _committing = true;
        try
        {
            var n = await Importer.CommitAsync(ApplicationContext, _result.Rows);
            Snackbar.Add($"Đã nhập {n} chứng từ.", Severity.Success);
            Navigation.NavigateTo("/pit/certificates");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Nhập thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _committing = false;
        }
    }

    private void Reset()
    {
        _fileName = null;
        _fileSize = 0;
        _result = null;
    }
}
