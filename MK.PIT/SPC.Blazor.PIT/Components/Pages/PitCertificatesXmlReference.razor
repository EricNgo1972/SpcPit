@using SPC.BO.PIT.Pdf

<div>
    <MudText Typo="Typo.body2" Class="mb-3">
        Mỗi chứng từ khấu trừ thuế TNCN được tạo thành tệp XML UTF-8 theo đặc tả kỹ thuật của Tổng cục Thuế
        tại <b>Quyết định 1306/QĐ-TCT (13/06/2025)</b>.
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Cấu trúc bao gói (§II)</MudText>
            <MudPaper Class="pa-3" Style="font-family: var(--mud-typography-body1-family, monospace); font-size: 0.8rem; white-space: pre; overflow-x: auto;" Elevation="0">
@($@"<{PitXmlSchema.TDiep}>
  <{PitXmlSchema.TTChung}>            Message header
    <{PitXmlSchema.PBan}>              Schema version (PitSettings.XmlSchemaVersion)
    <{PitXmlSchema.MNGui}>             Sender code (PitSettings.SenderCode)
    <{PitXmlSchema.MNNhan}>            Receiver = ""{PitXmlSchema.TaxAuthorityReceiver}""
    <{PitXmlSchema.MLTDiep}>           Message type (PitSettings.XmlMessageTypeCode)
    <{PitXmlSchema.MTDiep}>            32-char UUID, uppercase, no dashes
    <{PitXmlSchema.MTDTChieu}>         Replacement ref (RelatedProformaNo)
    <{PitXmlSchema.MST}>               Employer MST
    <{PitXmlSchema.SLuong}>1</{PitXmlSchema.SLuong}>
  <{PitXmlSchema.DLieu}>
    <{PitXmlSchema.CTDTKhauTru}>       One cert per document
      <{PitXmlSchema.DLCT}>
        <{PitXmlSchema.TTChungCTu}>    Certificate identification
        <{PitXmlSchema.TTTo}>          Organization (employer)
        <{PitXmlSchema.TTNNT}>         Tax payer (staff)
        <{PitXmlSchema.TTKhauTru}>     Withholding figures
      <{PitXmlSchema.Signature} xmlns=""{PitXmlSchema.SignatureNs}""/>
")
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Quy tắc định dạng (§I)</MudText>
            <MudList T="string" Dense="true" DisablePadding="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Code">
                    <MudText Typo="Typo.body2">UTF-8, no BOM, <code>TCVN 6909:2001</code>.</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Schedule">
                    <MudText Typo="Typo.body2"><code>yyyy-MM-dd</code> / <code>yyyy-MM-ddTHH:mm:ss</code> GMT+7.</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Calculate">
                    <MudText Typo="Typo.body2">Số tiền: tối đa 21 chữ số, tối đa 6 chữ số thập phân, dùng invariant culture.</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.DataUsage">
                    <MudText Typo="Typo.body2">Mỗi thông điệp &lt;= <b>2 MB</b>. Mỗi tệp chỉ chứa một chứng từ.</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Fingerprint">
                    <MudText Typo="Typo.body2">Chữ ký số W3C XML Digital Signature; LocalAgent sẽ điền vào thẻ placeholder rỗng.</MudText>
                </MudListItem>
            </MudList>
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Ánh xạ trường -> XML</MudText>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                <thead>
                    <tr><th>Nhóm</th><th>Trường chứng từ</th><th>Phần tử XML</th><th>Nguồn</th></tr>
                </thead>
                <tbody>
                    @foreach (var row in _mappingTable)
                    {
                        <tr>
                            <td><MudChip T="string" Size="Size.Small" Color="@row.Color">@row.Group</MudChip></td>
                            <td><code>@row.Field</code></td>
                            <td><code>@row.XmlTag</code></td>
                            <td>@row.Source</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Quy trình</MudText>
            <MudText Typo="Typo.body2" Class="mb-2">
                <code>Nháp</code> → <code>Đã tạo XML</code> → <code>Đã ký</code> →
                <code>Đã gửi</code> → <code>Chấp nhận</code> (đã khóa) hoặc <code>Từ chối</code>.
            </MudText>
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                Cần đối chiếu thêm với phụ lục QĐ 1306: mã <code>MLTDiep</code> chính xác cho "Chứng từ khấu trừ thuế TNCN"
                và tên các phần tử con <code>DLCT</code>. Nếu cần sửa, thay đổi sẽ được gom trong
                <code>PitXmlSchema.cs</code>.
            </MudAlert>
        </MudItem>
    </MudGrid>
</div>

@code {
    private sealed record MappingRow(string Group, string Field, string XmlTag, string Source, Color Color);

    private static readonly IReadOnlyList<MappingRow> _mappingTable =
    [
        new("Envelope",    "—",                                    $"{PitXmlSchema.TTChung}/{PitXmlSchema.PBan}",       "PitSettings.XmlSchemaVersion",            Color.Primary),
        new("Envelope",    "—",                                    $"{PitXmlSchema.TTChung}/{PitXmlSchema.MNGui}",      "PitSettings.SenderCode",                  Color.Primary),
        new("Envelope",    "—",                                    $"{PitXmlSchema.TTChung}/{PitXmlSchema.MLTDiep}",    "PitSettings.XmlMessageTypeCode",          Color.Primary),
        new("Envelope",    "—",                                    $"{PitXmlSchema.TTChung}/{PitXmlSchema.MTDiep}",     "Auto: 32-char UUID + sender prefix",      Color.Primary),
        new("Envelope",    "RelatedProformaNo (if replacement)",   $"{PitXmlSchema.TTChung}/{PitXmlSchema.MTDTChieu}",  "PitCertificate.RelatedProformaNo",        Color.Primary),
        new("Envelope",    "—",                                    $"{PitXmlSchema.TTChung}/{PitXmlSchema.MST}",        "PitSettings.OrganizationTaxCode",         Color.Primary),

        new("Cert id",     "ProformaNo",                           $"{PitXmlSchema.TTChungCTu}/{PitXmlSchema.CertNumber}",  "PitCertificate.ProformaNo",         Color.Info),
        new("Cert id",     "TaxPayerCode",                         $"{PitXmlSchema.TTChungCTu}/{PitXmlSchema.CertFormNo}",  "PitCertificate.TaxPayerCode",       Color.Info),
        new("Cert id",     "RelatedFormNo / RelatedProformaNo",    $"{PitXmlSchema.TTChungCTu}/{PitXmlSchema.RelatedCert}", "PitCertificate (replacement only)", Color.Info),

        new("Organization","—",                                    $"{PitXmlSchema.TTTo}/{PitXmlSchema.TMST}",          "PitSettings.OrganizationTaxCode",         Color.Secondary),
        new("Organization","—",                                    $"{PitXmlSchema.TTTo}/{PitXmlSchema.OName}",         "PitSettings.OrganizationName",            Color.Secondary),
        new("Organization","—",                                    $"{PitXmlSchema.TTTo}/{PitXmlSchema.OAddress}",      "PitSettings.OrganizationAddress",         Color.Secondary),
        new("Organization","—",                                    $"{PitXmlSchema.TTTo}/{PitXmlSchema.OPhone}",        "PitSettings.OrganizationPhone",           Color.Secondary),
        new("Organization","—",                                    $"{PitXmlSchema.TTTo}/{PitXmlSchema.OEmail}",        "PitSettings.OrganizationEmail",           Color.Secondary),

        new("Tax payer",   "TaxPayerName",                         $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TName}",        "PitCertificate.TaxPayerName",             Color.Success),
        new("Tax payer",   "TaxPayerTaxCode",                      $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TMST}",         "PitCertificate.TaxPayerTaxCode",          Color.Success),
        new("Tax payer",   "Nationality",                          $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TNat}",         "PitCertificate.Nationality",              Color.Success),
        new("Tax payer",   "ResidentType",                         $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TResType}",     "PitCertificate.ResidentType",             Color.Success),
        new("Tax payer",   "IdentificationNo",                     $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TIdNo}",        "PitCertificate.IdentificationNo",         Color.Success),
        new("Tax payer",   "IssueDate",                            $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TIssueDate}",   "PitCertificate.IssueDate (yyyy-MM-dd)",   Color.Success),
        new("Tax payer",   "IssuePlace",                           $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TIssuePlace}",  "PitCertificate.IssuePlace",               Color.Success),
        new("Tax payer",   "Phone",                                $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TPhone}",       "PitCertificate.Phone",                    Color.Success),
        new("Tax payer",   "Email",                                $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TEmail}",       "PitCertificate.Email",                    Color.Success),
        new("Tax payer",   "Address",                              $"{PitXmlSchema.TTNNT}/{PitXmlSchema.TAddress}",     "PitCertificate.Address",                  Color.Success),

        new("Withholding", "IncomePaymentYear",                    $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TPeriodYear}",  "PitCertificate.IncomePaymentYear",      Color.Warning),
        new("Withholding", "IncomePaymentMonthFrom",               $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TPeriodFrom}",  "PitCertificate.IncomePaymentMonthFrom", Color.Warning),
        new("Withholding", "IncomePaymentMonthTo",                 $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TPeriodTo}",    "PitCertificate.IncomePaymentMonthTo",   Color.Warning),
        new("Withholding", "IncomeType",                           $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TIncomeType}",  "PitCertificate.IncomeType",             Color.Warning),
        new("Withholding", "TotalTaxableIncome",                   $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TTaxableIncome}","PitCertificate.TotalTaxableIncome",    Color.Warning),
        new("Withholding", "AmountPersonalIncomeTax",              $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TTaxWithheld}", "PitCertificate.AmountPersonalIncomeTax", Color.Warning),
        new("Withholding", "InsurancePremiums",                    $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TInsurance}",   "PitCertificate.InsurancePremiums",      Color.Warning),
        new("Withholding", "CharityDonations",                     $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TCharity}",     "PitCertificate.CharityDonations",       Color.Warning),
        new("Withholding", "IncomeStillReceivable",                $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TStillReceivable}","PitCertificate.IncomeStillReceivable", Color.Warning),
        new("Withholding", "Note",                                 $"{PitXmlSchema.TTKhauTru}/{PitXmlSchema.TNote}",        "PitCertificate.Note",                   Color.Warning),
    ];
}
