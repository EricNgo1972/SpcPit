<div>
    <MudText Typo="Typo.body2" Class="mb-3">
        Viettel T-VAN nhận chứng từ dưới dạng <b>JSON có cấu trúc</b> tại
        <code>/api/InvoiceAPI/InvoiceWS/createTaxDeductionCertificate/{supplierTaxCode}</code>. Viettel tự ký
        (CTS Server) và chuyển tiếp đến cơ quan thuế. Ứng dụng không gửi XML QĐ 1306 qua đường truyền;
        XML chỉ được tạo nội bộ cho mục đích đối chiếu và lưu trữ.
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="7">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Dữ liệu gửi đi</MudText>
            <MudList T="string" Dense="true" DisablePadding="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Segment">
                    <MudText Typo="Typo.body2"><b>generalInvoiceInfo</b> — thông tin bao gói (ký hiệu, loại, ngày, loại điều chỉnh, tham chiếu thay thế)</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                    <MudText Typo="Typo.body2"><b>taxPayerInfo</b> — thông tin người nộp thuế (tên, MST, cư trú, giấy tờ, liên hệ)</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Calculate">
                    <MudText Typo="Typo.body2"><b>incomeInfo</b> — kỳ tính thuế, thu nhập tính thuế, giảm trừ, thuế TNCN đã khấu trừ</MudText>
                </MudListItem>
            </MudList>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Dữ liệu nhận về</MudText>
            <MudList T="string" Dense="true" DisablePadding="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Receipt">
                    <MudText Typo="Typo.body2"><b>invoiceNo</b> — e.g. <code>CT/25E113</code></MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Tag">
                    <MudText Typo="Typo.body2"><b>transactionID</b> — mã giao dịch theo dõi của Viettel</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.VpnKey">
                    <MudText Typo="Typo.body2"><b>reservationCode</b> — mã bí mật để tra cứu</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Verified">
                    <MudText Typo="Typo.body2"><b>codeOfTax</b> — mã CQT thực (thường trả về bất đồng bộ; tạm thời dùng reservationCode nếu chưa có)</MudText>
                </MudListItem>
            </MudList>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-3" />

    <MudText Typo="Typo.subtitle2" Class="mb-2">Quy trình với Viettel</MudText>
    <MudText Typo="Typo.body2" Class="mb-2">
        <code>Nháp</code> → <i>Gửi nộp</i> → <code>Đã gửi</code> →
        <code>Chấp nhận</code> (đã khóa, chỉ được tải xuống) hoặc <code>Từ chối</code>.
        Không có bước Tạo XML / Ký số trong quy trình gửi nộp chính.
    </MudText>

    <MudStack Row="true" Spacing="2" Class="mt-3">
        <MudButton Href="/pit/settings/viettel" Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Settings">
            Cài đặt dịch vụ Viettel
        </MudButton>
        <MudButton Href="docs/Viettel.md" Target="_blank" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.MenuBook">
            Tài liệu tích hợp đầy đủ
        </MudButton>
    </MudStack>

    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
        Trước khi vận hành thật: đăng ký <b>ký hiệu chứng từ</b> (ví dụ <code>CT/25E</code>) trên cổng Viettel,
        khai báo thông tin đăng nhập và SupplierTaxCode trong trang Cài đặt dịch vụ Viettel, sau đó kiểm tra
        gửi thử một chứng từ trên môi trường test của Viettel.
    </MudAlert>
</div>
