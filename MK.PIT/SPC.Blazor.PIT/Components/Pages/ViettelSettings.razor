@page "/pit/settings/viettel"
@inject Csla.ApplicationContext ApplicationContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject SPC.Infrastructure.TvanSubmission.Viettel.ViettelTvanSubmissionService ViettelService

<PageTitle>Cài đặt dịch vụ Viettel</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/pit/settings"))" />
    <MudText Typo="Typo.h4">Cài đặt dịch vụ Viettel</MudText>
</MudStack>

<MudAlert Severity="Severity.Info" Class="mb-4" Icon="@Icons.Material.Filled.Gavel">
    Cấu hình kết nối và thông tin mẫu số cho Viettel T-VAN (<b>Chứng từ khấu trừ thuế TNCN</b>, CTS Server flow).
    Được lưu nội bộ trong cơ sở dữ liệu của ứng dụng. Giá trị mới sẽ có hiệu lực ở lần gửi tiếp theo, không cần khởi động lại.
</MudAlert>

@if (_settings is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudAlert Severity="@(_settings.IsReadyForSubmission ? Severity.Success : Severity.Warning)" Dense="true" Class="mb-4"
              Icon="@(_settings.IsReadyForSubmission ? Icons.Material.Filled.Verified : Icons.Material.Filled.Warning)">
        Trạng thái:
        <b>@(_settings.IsReadyForSubmission ? "Sẵn sàng" : "Chưa sẵn sàng")</b>
        @if (_settings.LastConnectionTestUtc is not null)
        {
            <span> · Lần kiểm tra cuối: @_settings.LastConnectionTestUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
        }
        @if (!string.IsNullOrWhiteSpace(_settings.LastConnectionTestMessage))
        {
            <div>@_settings.LastConnectionTestMessage</div>
        }
        @if (!_settings.IsReadyForSubmission && !string.IsNullOrWhiteSpace(_settings.LastTestedConfigHash))
        {
            <div>Cấu hình đã thay đổi sau lần kiểm tra thành công cuối cùng. Hãy chạy Kiểm tra kết nối lại.</div>
        }
    </MudAlert>

    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Endpoint</MudText>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField Label="Base URL" @bind-Value="_settings.BaseUrl" Required="true"
                              HelperText="Moi truong that: https://api-sinvoice.viettel.vn · Moi truong test: URL sandbox do Viettel cap" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Đường dẫn đăng nhập" @bind-Value="_settings.LoginPath"
                              HelperText="Mặc định: /auth/login" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Đường dẫn gửi chứng từ" @bind-Value="_settings.SubmitPath"
                              HelperText="Dùng {mst} làm chỗ đặt cho mã số thuế đơn vị." />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">Thông tin đăng nhập</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Tên đăng nhập" @bind-Value="_settings.Username" Required="true"
                              HelperText="Tài khoản do Viettel cấp, thường có dạng MST-hậu tố, ví dụ 0100109106-712" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Mật khẩu" @bind-Value="_settings.Password" Required="true"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Mã số thuế đơn vị" @bind-Value="_settings.SupplierTaxCode" Required="true"
                              HelperText="Sẽ thay thế cho {mst} trong đường dẫn gửi chứng từ." />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">Thông tin chứng từ</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Ký hiệu chứng từ" @bind-Value="_settings.InvoiceSeries" Required="true"
                              HelperText="Phải trùng với ký hiệu đã đăng ký trên cổng Viettel, ví dụ CT/25E." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Loại chứng từ" @bind-Value="_settings.InvoiceType"
                              HelperText="Cố định là 03/TNCN đối với chứng từ khấu trừ thuế TNCN." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Mã mẫu" @bind-Value="_settings.TemplateCode"
                              HelperText="Cố định là 03/TNCN đối với chứng từ khấu trừ thuế TNCN." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Mã tiền tệ" @bind-Value="_settings.CurrencyCode" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">Tham số kỹ thuật</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudNumericField T="int" Label="Số giây làm mới token sớm" @bind-Value="_settings.TokenRefreshSkewSeconds"
                                 HelperText="Làm mới access_token trong bộ nhớ đệm sớm hơn từng này giây trước khi hết hạn." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="int" Label="Timeout yêu cầu (giây)" @bind-Value="_settings.TimeoutSeconds" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving">
                @(_saving ? "Đang lưu..." : "Lưu")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="TestConnectionAsync" Disabled="@(_saving || _testing)">
                @(_testing ? "Đang kiểm tra..." : "Kiểm tra kết nối")
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/pit/settings"))">Quay lại cài đặt PIT</MudButton>
        </MudStack>
    </MudPaper>

    <MudAlert Severity="Severity.Success" Class="mt-4" Icon="@Icons.Material.Filled.Lock">
        Mật khẩu sẽ được mã hóa trước khi ghi vào cơ sở dữ liệu bằng ASP.NET Core Data Protection.
        Khóa mã hóa nằm trong <code>{ContentRoot}/keys</code> - hãy sao lưu thư mục này cùng với
        <code>spc-pit.db</code>, nếu không mật khẩu đã lưu sẽ không thể giải mã và phải nhập lại.
    </MudAlert>
}

@code {
    private SPC.BO.PIT.ViettelSettings? _settings;
    private bool _saving;
    private bool _testing;
    private bool _showPassword;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SPC.BO.PIT.ViettelSettings.GetViettelSettingsAsync(ApplicationContext);
    }

    private async Task SaveAsync()
    {
        if (_settings is null) return;
        _saving = true;
        try
        {
            _settings = await _settings.SaveAsync();
            Snackbar.Add("Đã lưu cài đặt Viettel. Sẽ áp dụng ở lần gửi nộp tiếp theo.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lưu thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task TestConnectionAsync()
    {
        if (_settings is null) return;

        _testing = true;
        try
        {
            var result = await ViettelService.TestConnectionAsync(ToOptions(_settings));
            _settings.ConnectionReady = result.Success;
            _settings.LastConnectionTestUtc = DateTime.UtcNow;
            _settings.LastConnectionTestMessage = result.Message;
            _settings.LastTestedConfigHash = result.Success ? _settings.ComputeConnectionConfigHash() : string.Empty;
            _settings = await _settings.SaveAsync();

            Snackbar.Add(
                result.Success
                    ? "Kiểm tra kết nối Viettel thành công. Nhà cung cấp đã được đánh dấu Sẵn sàng."
                    : $"Kiểm tra kết nối Viettel thất bại: {result.Message}",
                result.Success ? Severity.Success : Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kiểm tra kết nối thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testing = false;
        }
    }

    private static SPC.Infrastructure.TvanSubmission.ViettelOptions ToOptions(SPC.BO.PIT.ViettelSettings settings) =>
        new()
        {
            BaseUrl = settings.BaseUrl,
            LoginPath = settings.LoginPath,
            SubmitPath = settings.SubmitPath,
            Username = settings.Username,
            Password = settings.Password,
            SupplierTaxCode = settings.SupplierTaxCode,
            InvoiceSeries = settings.InvoiceSeries,
            InvoiceType = settings.InvoiceType,
            TemplateCode = settings.TemplateCode,
            CurrencyCode = settings.CurrencyCode,
            TokenRefreshSkewSeconds = settings.TokenRefreshSkewSeconds,
            TimeoutSeconds = settings.TimeoutSeconds
        };
}
