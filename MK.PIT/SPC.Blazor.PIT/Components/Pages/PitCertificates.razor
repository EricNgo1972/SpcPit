@page "/pit/certificates"
@using System.IO.Compression
@using System.Globalization
@using System.Text
@using SPC.BO.PIT.Pdf
@using SPC.Infrastructure.TvanSubmission
@inject Csla.ApplicationContext ApplicationContext
@inject IXmlSigningService SigningService
@inject ITvanSubmissionService TvanService
@inject PitPdfBuilder PdfBuilder
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Chứng từ PIT</PageTitle>
<MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="2" Class="mb-4">
    <MudText Typo="Typo.h4">Chứng từ</MudText>
    <MudChip T="string" Size="Size.Small" Color="@(_provider.IsAvailable ? Color.Primary : Color.Warning)"
             Icon="@Icons.Material.Filled.Cable">
        Nhà cung cấp: @_provider.DisplayName
    </MudChip>
    @if (_provider.Code == TvanProviderCatalog.ViettelCode)
    {
        <MudChip T="string" Size="Size.Small" Color="@(_providerReady ? Color.Success : Color.Warning)"
                 Variant="Variant.Outlined" Icon="@Icons.Material.Filled.VerifiedUser">
            @(_providerReady ? "Sẵn sàng" : "Chưa sẵn sàng")
        </MudChip>
    }
    @if (!_provider.IsAvailable && _provider.Code != TvanProviderCatalog.NoneCode)
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
            chưa hỗ trợ - gửi nộp sẽ thất bại
        </MudChip>
    }
</MudStack>

@* Help content adapts to the selected T-VAN provider:
   - None                  → prompt to configure a provider
   - JSON-based (Viettel,  → provider-specific flow + link to its docs; QĐ 1306 XML is optional
     Stub)                   and relegated to a secondary collapsible
   - XML-requiring         → full QĐ 1306 reference (envelope, rules, mapping, lifecycle)
*@
<MudExpansionPanels Elevation="0" Class="mb-4">
    <MudExpansionPanel Text="@HelpPanelTitle" Icon="@HelpPanelIcon">
        @if (_provider.Code == TvanProviderCatalog.NoneCode)
        {
            @NoProviderHelp()
        }
        else if (_provider.Code == TvanProviderCatalog.ViettelCode)
        {
            @ViettelHelp()
        }
        else if (_provider.Code == TvanProviderCatalog.StubCode)
        {
            @StubHelp()
        }
        else
        {
            @XmlProviderHelp()
        }
    </MudExpansionPanel>

  
</MudExpansionPanels>

@* Toolbar buttons adapt to the active provider. XML-related actions (Generate / Sign /
   Download XML) are rendered only for providers that actually need signed XML bytes —
   for Viettel & Stub they would confuse the workflow (Viettel signs internally). *@
<MudPaper Class="pa-3 mb-3" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.subtitle2">
            Đã chọn @_selected.Count
        </MudText>

        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Edit"
                   Disabled="@(_selected.Count != 1 || _busy)"
                   OnClick="OpenSelected">
            Mở
        </MudButton>

        @if (_provider.RequiresSignedXml)
        {
            <MudDivider Vertical="true" FlexItem="true" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Build"
                       Disabled="@(!_selected.Any() || _busy)"
                       OnClick="GenerateBulkAsync">
                Tạo XML
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.Fingerprint"
                       Disabled="@(!_selected.Any() || _busy)"
                       OnClick="SignBulkAsync">
                Ký số
            </MudButton>
        }

        @if (_provider.Code != TvanProviderCatalog.NoneCode)
        {
            <MudDivider Vertical="true" FlexItem="true" />

            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Send"
                       Disabled="@(!_selected.Any() || _busy || !_providerReady)"
                       OnClick="SubmitBulkAsync">
                Gửi nộp qua @_provider.DisplayName
            </MudButton>
        }

        <MudDivider Vertical="true" FlexItem="true" />

        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   Disabled="@(!_selected.Any() || _busy)"
                   OnClick="GeneratePdfBulkAsync">
            Tải PDF
        </MudButton>

        @if (_provider.RequiresSignedXml)
        {
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(!_selected.Any() || _busy)"
                       OnClick="@(() => DownloadBulkAsync(signed: false))">
                Tải XML chưa ký
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(!_selected.Any() || _busy)"
                       OnClick="@(() => DownloadBulkAsync(signed: true))">
                Tải XML đã ký
            </MudButton>
        }

        @if (_busy)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
    </MudStack>
</MudPaper>

<MudStack Row="true" Class="mb-3" Spacing="2">
    <MudSelect T="string" Label="Trạng thái" @bind-Value="_statusFilter" Clearable="true" Dense="true">
        @foreach (var s in CertificateStatus.All)
        {
            <MudSelectItem T="string" Value="@s">@DisplayStatus(s)</MudSelectItem>
        }
    </MudSelect>
    <MudTextField T="int?" Label="Năm" @bind-Value="_yearFilter" />
    <MudTextField T="string" Label="Tìm tên/MST" @bind-Value="_search" />
</MudStack>

@if (_certs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable T="PitCertificateInfo" Items="Filtered" Dense="true" Hover="true" Bordered="true"
              MultiSelection="true" @bind-SelectedItems="_selected">
        <HeaderContent>
            <MudTh>ProformaNo</MudTh>
            <MudTh>Họ tên</MudTh>
            <MudTh>Mã số thuế</MudTh>
            <MudTh>Năm</MudTh>
            <MudTh>Thu nhập tính thuế</MudTh>
            <MudTh>Đã khấu trừ</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Mã CQT</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProformaNo</MudTd>
            <MudTd>@context.TaxPayerName</MudTd>
            <MudTd>@context.TaxPayerTaxCode</MudTd>
            <MudTd>@context.IncomePaymentYear</MudTd>
            <MudTd>@context.TotalTaxableIncome.ToString("N0")</MudTd>
            <MudTd>@context.AmountPersonalIncomeTax.ToString("N0")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@DisplayStatus(context.Status)</MudChip>
                @if (IsLocked(context))
                {
                    <MudTooltip Text="Đã khóa: cơ quan thuế đã cấp mã CQT. Chỉ được tải xuống.">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Success" Class="ml-1" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd>@context.CqtCode</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private PitCertificateInfoList? _certs;
    private HashSet<PitCertificateInfo> _selected = [];
    private string? _statusFilter;
    private int? _yearFilter;
    private string? _search;
    private bool _busy;
    private TvanProviderInfo _provider = TvanProviderCatalog.Stub;
    private bool _providerReady = true;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
        _provider = TvanProviderCatalog.Get(settings.TvanProviderName);
        _providerReady = await ResolveProviderReadyAsync(_provider);
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _certs = await PitCertificateInfoList.GetAllAsync(ApplicationContext);
        _selected = [];
    }

    private IEnumerable<PitCertificateInfo> Filtered =>
        (_certs ?? Enumerable.Empty<PitCertificateInfo>())
            .Where(c => string.IsNullOrEmpty(_statusFilter) || c.Status == _statusFilter)
            .Where(c => !_yearFilter.HasValue || c.IncomePaymentYear == _yearFilter.Value)
            .Where(c => string.IsNullOrWhiteSpace(_search)
                       || c.TaxPayerName.Contains(_search, StringComparison.OrdinalIgnoreCase)
                       || c.TaxPayerTaxCode.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private static Color StatusColor(string status) => status switch
    {
        CertificateStatus.Draft => Color.Default,
        CertificateStatus.XmlGenerated => Color.Info,
        CertificateStatus.Signed => Color.Warning,
        CertificateStatus.Submitted => Color.Warning,
        CertificateStatus.Accepted => Color.Success,
        CertificateStatus.Rejected => Color.Error,
        _ => Color.Default
    };

    // --- Eligibility ---
    // Accepted certificates are LOCKED: they have a mã CQT issued by the tax authority and must
    // not be mutated. Only downloads are permitted on locked rows.
    // Sign/Submit are additionally idempotent: running them on an already-past-step row is a no-op.
    // Generate XML is otherwise always allowed — the user can regenerate at any time.

    private static bool IsLocked(PitCertificateInfo c) => c.Status == CertificateStatus.Accepted;

    // Generate XML and Sign remain optional audit utilities — useful for local archival,
    // cross-checking, and providers that want signed bytes. With Viettel they are NOT
    // required before Submit (Viettel takes structured JSON and signs internally).
    private static bool CanGenerate(PitCertificateInfo c) => !IsLocked(c);
    private static bool CanSign(PitCertificateInfo c)     => !IsLocked(c) && c.Status == CertificateStatus.XmlGenerated;

    // Submit is allowed from any non-locked, non-in-flight state (Draft / XmlGenerated /
    // Signed / Rejected). Viettel doesn't need the XML; other providers that do need it
    // will just need Generate + Sign run first to populate the bytes.
    private static bool CanSubmit(PitCertificateInfo c)   =>
        !IsLocked(c) && c.Status != CertificateStatus.Submitted;

    // --- Single-row open ---

    private void OpenSelected()
    {
        var c = _selected.SingleOrDefault();
        if (c is not null)
            Navigation.NavigateTo($"/pit/certificates/{c.PitCertificateId}");
    }

    // --- Bulk state-transition actions ---

    private async Task GenerateBulkAsync()
    {
        // Regenerates UnsignedXml + MessageId on every selected row except those that have
        // already received a mã CQT from the tax authority (those rows are locked).
        await RunBulkAsync(
            eligible: CanGenerate,
            action: id => PitXmlCommand.GenerateUnsignedAsync(ApplicationContext, id),
            verb: "Tạo XML",
            skipReason: "đã khóa (đã có mã CQT)");
    }

    private async Task SignBulkAsync()
    {
        await RunBulkAsync(
            eligible: CanSign,
            action: async id =>
            {
                var cert = await ApplicationContext.GetRequiredService<IDataPortalFactory>()
                    .GetPortal<PitCertificate>().FetchAsync(id);
                var signed = await SigningService.SignAsync(cert.UnsignedXml ?? []);
                await PitXmlCommand.MarkSignedAsync(ApplicationContext, id, signed);
            },
            verb: "Ký số",
            skipReason: "đã khóa, đã ký hoặc chưa tạo XML");
    }

    private async Task SubmitBulkAsync()
    {
        if (!_providerReady)
        {
            Snackbar.Add("Nhà cung cấp hiện tại chưa sẵn sàng để gửi nộp. Hãy hoàn tất cấu hình trước.", Severity.Warning);
            return;
        }

        var settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
        var settingsInput = PitSettingsXmlInput.From(settings);

        await RunBulkAsync(
            eligible: CanSubmit,
            action: async id =>
            {
                var cert = await ApplicationContext.GetRequiredService<IDataPortalFactory>()
                    .GetPortal<PitCertificate>().FetchAsync(id);
                await PitXmlCommand.MarkSubmittedAsync(ApplicationContext, id);

                var req = new TvanSubmissionRequest(
                    Certificate: PitCertificateXmlInput.From(cert),
                    Settings: settingsInput,
                    SignedXml: cert.SignedXml);
                var response = await TvanService.SubmitAsync(req);

                if (response.Accepted)
                    await PitXmlCommand.MarkAcceptedAsync(ApplicationContext, id,
                        response.CqtCode ?? response.InvoiceNo ?? "");
                else
                    await PitXmlCommand.MarkRejectedAsync(ApplicationContext, id,
                        response.RejectReason ?? "Từ chối");
            },
            verb: "Gửi nộp",
            skipReason: "đã khóa hoặc đã gửi");
    }

    /// <summary>
    /// Core bulk runner: iterates the current selection, calls <paramref name="action"/> on every
    /// row that satisfies <paramref name="eligible"/>, and silently skips the rest. Presents a
    /// consolidated summary snackbar so repeating the same action is always safe (no-op on
    /// already-completed rows) — second-run guarantee.
    /// </summary>
    private async Task RunBulkAsync(
        Func<PitCertificateInfo, bool> eligible,
        Func<string, Task> action,
        string verb,
        string skipReason)
    {
        if (_selected.Count == 0) return;
        _busy = true;
        var snapshot = _selected.ToList();
        var done = 0;
        var skipped = 0;
        var failed = 0;
        string? lastError = null;

        foreach (var row in snapshot)
        {
            if (!eligible(row)) { skipped++; continue; }
            try
            {
                await action(row.PitCertificateId);
                done++;
            }
            catch (Exception ex)
            {
                failed++;
                lastError = ex.Message;
            }
        }

        _busy = false;

        var parts = new List<string>();
        parts.Add($"{done} xong");
        if (skipped > 0) parts.Add($"{skipped} bỏ qua ({skipReason})");
        if (failed > 0)  parts.Add($"{failed} thất bại");
        var message = $"{verb}: " + string.Join(", ", parts) + ".";

        var severity = failed > 0 ? Severity.Error
                     : done == 0 ? Severity.Info
                     : Severity.Success;

        if (failed > 0 && lastError is not null)
            message += $" Lỗi cuối: {lastError}";

        Snackbar.Add(message, severity);
        await ReloadAsync();
    }

    // --- Bulk PDF: single cert → .pdf, multiple → .zip ---

    private async Task GeneratePdfBulkAsync()
    {
        if (_selected.Count == 0) return;
        _busy = true;
        try
        {
            var portal = ApplicationContext.GetRequiredService<IDataPortalFactory>().GetPortal<PitCertificate>();
            var settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
            var settingsInput = PitSettingsXmlInput.From(settings);

            var payloads = new List<(string Name, byte[] Bytes)>();

            foreach (var row in _selected)
            {
                var cert = await portal.FetchAsync(row.PitCertificateId);
                var ctx = new PitPdfBuildContext(
                    Certificate: PitCertificateXmlInput.From(cert),
                    Settings: settingsInput,
                    CqtCode: cert.CqtCode,
                    FormNumber: null,
                    Series: null,
                    IssuedOn: null);
                var bytes = PdfBuilder.Build(ctx);
                payloads.Add((BuildPdfFileName(cert), bytes));
            }

            if (payloads.Count == 1)
            {
                var (name, bytes) = payloads[0];
                await JS.InvokeVoidAsync("spcPitDownload",
                    name, Convert.ToBase64String(bytes), "application/pdf");
            }
            else
            {
                var zipName = $"pit-pdf-{DateTime.Now:yyyyMMdd-HHmmss}.zip";
                using var ms = new MemoryStream();
                using (var zip = new ZipArchive(ms, ZipArchiveMode.Create, leaveOpen: true))
                {
                    foreach (var (name, bytes) in payloads)
                    {
                        var entry = zip.CreateEntry(name, CompressionLevel.Fastest);
                        using var entryStream = entry.Open();
                        await entryStream.WriteAsync(bytes);
                    }
                }
                await JS.InvokeVoidAsync("spcPitDownload",
                    zipName, Convert.ToBase64String(ms.ToArray()), "application/zip");
            }

            Snackbar.Add($"Đã tạo {payloads.Count} tệp PDF.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Tạo PDF thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // --- Bulk XML downloads: single cert → .xml, multiple → .zip ---

    private async Task DownloadBulkAsync(bool signed)
    {
        if (_selected.Count == 0) return;
        _busy = true;
        try
        {
            var portal = ApplicationContext.GetRequiredService<IDataPortalFactory>().GetPortal<PitCertificate>();
            var payloads = new List<(string Name, byte[] Bytes)>();
            var skipped = 0;

            foreach (var row in _selected)
            {
                var cert = await portal.FetchAsync(row.PitCertificateId);
                var bytes = signed ? cert.SignedXml : cert.UnsignedXml;
                if (bytes is null || bytes.Length == 0) { skipped++; continue; }
                payloads.Add(($"{cert.ProformaNo}-{(signed ? "signed" : "unsigned")}.xml", bytes));
            }

            if (payloads.Count == 0)
            {
                Snackbar.Add($"Không có XML {(signed ? "đã ký" : "chưa ký")} trong các dòng đã chọn.", Severity.Warning);
                return;
            }

            if (payloads.Count == 1)
            {
                var (name, bytes) = payloads[0];
                await JS.InvokeVoidAsync("spcPitDownload",
                    name, Convert.ToBase64String(bytes), "application/xml");
            }
            else
            {
                var zipName = $"pit-{(signed ? "signed" : "unsigned")}-{DateTime.Now:yyyyMMdd-HHmmss}.zip";
                using var ms = new MemoryStream();
                using (var zip = new ZipArchive(ms, ZipArchiveMode.Create, leaveOpen: true))
                {
                    foreach (var (name, bytes) in payloads)
                    {
                        var entry = zip.CreateEntry(name, CompressionLevel.Fastest);
                        using var entryStream = entry.Open();
                        await entryStream.WriteAsync(bytes);
                    }
                }
                await JS.InvokeVoidAsync("spcPitDownload",
                    zipName, Convert.ToBase64String(ms.ToArray()), "application/zip");
            }

            if (skipped > 0)
                Snackbar.Add($"Đã tải {payloads.Count} tệp, bỏ qua {skipped} dòng (chưa có XML).", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Tải xuống thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // --- Provider-aware help content ------------------------------------------------------

    private string HelpPanelTitle =>
        _provider.Code == TvanProviderCatalog.NoneCode
            ? "Chưa chọn nhà cung cấp T-VAN"
            : $"Quy trình gửi nộp với {_provider.DisplayName}";

    private string HelpPanelIcon =>
        _provider.Code == TvanProviderCatalog.NoneCode ? Icons.Material.Filled.Warning
        : _provider.RequiresSignedXml                   ? Icons.Material.Filled.Gavel
                                                        : Icons.Material.Filled.Info;

    private async Task<bool> ResolveProviderReadyAsync(TvanProviderInfo provider)
    {
        if (!provider.IsAvailable) return false;

        return provider.Code switch
        {
            TvanProviderCatalog.NoneCode => false,
            TvanProviderCatalog.ViettelCode => (await SPC.BO.PIT.ViettelSettings.GetViettelSettingsAsync(ApplicationContext)).IsReadyForSubmission,
            _ => true
        };
    }

    private static string DisplayStatus(string status) => status switch
    {
        CertificateStatus.Draft => "Nháp",
        CertificateStatus.XmlGenerated => "Đã tạo XML",
        CertificateStatus.Signed => "Đã ký",
        CertificateStatus.Submitted => "Đã gửi",
        CertificateStatus.Accepted => "Chấp nhận",
        CertificateStatus.Rejected => "Từ chối",
        _ => status
    };

    private static string BuildPdfFileName(PitCertificate cert)
    {
        var idPart = SanitizeFileNamePart(cert.ProformaNo);
        var namePart = SanitizeFileNamePart(RemoveDiacritics(cert.TaxPayerName));

        return string.IsNullOrWhiteSpace(namePart)
            ? $"CTKT-{idPart}.pdf"
            : $"CTKT-{idPart}-{namePart}.pdf";
    }

    private static string RemoveDiacritics(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Replace('đ', 'd').Replace('Đ', 'D')
            .Normalize(NormalizationForm.FormD);
        var buffer = new List<char>(normalized.Length);

        foreach (var ch in normalized)
        {
            if (CharUnicodeInfo.GetUnicodeCategory(ch) != UnicodeCategory.NonSpacingMark)
                buffer.Add(ch);
        }

        return new string(buffer.ToArray()).Normalize(NormalizationForm.FormC);
    }

    private static string SanitizeFileNamePart(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "unknown";

        var chars = value.Trim()
            .Select(ch => char.IsLetterOrDigit(ch) ? ch : '-')
            .ToArray();

        var sanitized = new string(chars);
        while (sanitized.Contains("--", StringComparison.Ordinal))
            sanitized = sanitized.Replace("--", "-", StringComparison.Ordinal);

        sanitized = sanitized.Trim('-');
        return string.IsNullOrWhiteSpace(sanitized) ? "unknown" : sanitized;
    }
}

@* =====================================================================================
   Help-panel render fragments. Kept at the end of the file for readability — the top of
   the razor invokes @NoProviderHelp(), @ViettelHelp(), etc. based on the active provider.
   ===================================================================================== *@

@code {
    private RenderFragment NoProviderHelp() => @<MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.Warning">
        <b>Chưa chọn nhà cung cấp T-VAN.</b> Nút <i>Gửi nộp</i> sẽ bị ẩn cho đến khi bạn chọn nhà cung cấp trong trang
        <MudLink Href="/pit/settings">Cài đặt PIT</MudLink>. Bạn vẫn có thể nhập liệu, tạo PDF và lưu trữ nội bộ.
    </MudAlert>;

    private RenderFragment ViettelHelp() => @<PitCertificatesViettelHelp />;

    private RenderFragment StubHelp() =>@<div>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3" Icon="@Icons.Material.Filled.Science">
            <b>Đang dùng nhà cung cấp Stub.</b> <i>Gửi nộp</i> sẽ trả về <code>invoiceNo</code> và <code>CqtCode</code>
            giả lập mà không gọi đến dịch vụ thật; phù hợp cho phát triển nội bộ và kiểm thử end-to-end. Hãy chuyển sang
            nhà cung cấp thật (ví dụ Viettel) trong trang <MudLink Href="/pit/settings">Cài đặt PIT</MudLink> trước khi đưa vào vận hành.
        </MudAlert>

        <MudText Typo="Typo.body2">
            Stub không cần <i>Tạo XML</i> hoặc <i>Ký số</i>, vì vậy các nút này được ẩn trên thanh công cụ.
            Bạn vẫn có thể tải PDF (tạo từ dữ liệu nội bộ) và mở từng chứng từ để chỉnh sửa.
        </MudText>
    </div>;

    private RenderFragment XmlProviderHelp() =>@<div>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            <b>Nhà cung cấp hiện tại: @_provider.DisplayName</b> — yêu cầu XML đã ký. Quy trình: <i>Tạo XML</i> →
            <i>Ký số</i> (qua LocalAgent) → <i>Gửi nộp</i>.
        </MudAlert>
        <PitCertificatesXmlReference />

    </div>;
}
