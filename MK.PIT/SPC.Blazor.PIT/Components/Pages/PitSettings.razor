@page "/pit/settings"
@using SPC.Infrastructure.TvanSubmission
@inject Csla.ApplicationContext ApplicationContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>PIT Settings</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

@if (_settings is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Organization (employer)</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Tax code (MST)" @bind-Value="_settings.OrganizationTaxCode" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Name" @bind-Value="_settings.OrganizationName" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Address" @bind-Value="_settings.OrganizationAddress" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Phone" @bind-Value="_settings.OrganizationPhone" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Email" @bind-Value="_settings.OrganizationEmail" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Representative name" @bind-Value="_settings.RepresentativeName" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Representative title" @bind-Value="_settings.RepresentativeTitle" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">QĐ 1306 envelope</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField Label="Sender code (MNGui prefix)" @bind-Value="_settings.SenderCode" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Label="Schema version (PBan)" @bind-Value="_settings.XmlSchemaVersion" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Label="Message type code (MLTDiep)" @bind-Value="_settings.XmlMessageTypeCode" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">External services</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="LocalAgent sign URL" @bind-Value="_settings.LocalAgentSignUrl"
                              HelperText="Only used when you Sign XML locally. Optional if your TVAN signs internally (e.g. Viettel)." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="TVAN provider" @bind-Value="_settings.TvanProviderName">
                    @foreach (var p in TvanProviderCatalog.All)
                    {
                        <MudSelectItem T="string" Value="@p.Code" Disabled="@(!p.IsAvailable)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText>@p.DisplayName</MudText>
                                @if (!p.IsAvailable)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">planned</MudChip>
                                }
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
                @{ var selected = TvanProviderCatalog.Get(_settings.TvanProviderName); }
                <MudText Typo="Typo.caption" Class="mt-1 d-block">@selected.Description</MudText>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (string.Equals(_settings.TvanProviderName, TvanProviderCatalog.ViettelCode, StringComparison.OrdinalIgnoreCase))
    {
        <MudPaper Class="pa-4 mt-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">Viettel T-VAN</MudText>
                    <MudText Typo="Typo.body2">Credentials, endpoints, and product series for Viettel SInvoice.</MudText>
                    @if (_viettelSettings is not null)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_viettelSettings.IsReadyForSubmission ? Color.Success : Color.Warning)"
                                 Variant="Variant.Outlined" Class="mt-2">
                            @(_viettelSettings.IsReadyForSubmission ? "Ready" : "Not ready")
                        </MudChip>
                    }
                </MudStack>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Settings"
                           OnClick="@(() => Navigation.NavigateTo("/pit/settings/viettel"))">
                    Viettel Service Settings
                </MudButton>
            </MudStack>
        </MudPaper>
    }
}

@code {
    private SPC.BO.PIT.PitSettings? _settings;
    private SPC.BO.PIT.ViettelSettings? _viettelSettings;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
        _viettelSettings = await SPC.BO.PIT.ViettelSettings.GetViettelSettingsAsync(ApplicationContext);
    }

    private async Task SaveAsync()
    {
        if (_settings is null) return;
        _saving = true;
        try
        {
            _settings = await _settings.SaveAsync();
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
