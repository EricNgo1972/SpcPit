@page "/pit/settings"
@using SPC.Infrastructure.TvanSubmission
@inject Csla.ApplicationContext ApplicationContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cài đặt PIT</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Cài đặt</MudText>

@if (_settings is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Thông tin đơn vị chi trả</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Mã số thuế" @bind-Value="_settings.OrganizationTaxCode" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Tên đơn vị" @bind-Value="_settings.OrganizationName" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Địa chỉ" @bind-Value="_settings.OrganizationAddress" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Điện thoại" @bind-Value="_settings.OrganizationPhone" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Email" @bind-Value="_settings.OrganizationEmail" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Người đại diện" @bind-Value="_settings.RepresentativeName" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Chức vụ người đại diện" @bind-Value="_settings.RepresentativeTitle" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">QĐ 1306 envelope</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField Label="Sender code (MNGui prefix)" @bind-Value="_settings.SenderCode" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Label="Schema version (PBan)" @bind-Value="_settings.XmlSchemaVersion" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField Label="Message type code (MLTDiep)" @bind-Value="_settings.XmlMessageTypeCode" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-3">Dịch vụ bên ngoài</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="URL ký số LocalAgent" @bind-Value="_settings.LocalAgentSignUrl"
                              HelperText="Chỉ dùng khi ký XML tại máy. Có thể bỏ trống nếu TVAN tự ký nội bộ, ví dụ Viettel." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Nhà cung cấp TVAN" @bind-Value="_settings.TvanProviderName">
                    @foreach (var p in TvanProviderCatalog.All)
                    {
                        <MudSelectItem T="string" Value="@p.Code" Disabled="@(!p.IsAvailable)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText>@p.DisplayName</MudText>
                                @if (!p.IsAvailable)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">dự kiến</MudChip>
                                }
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
                @{ var selected = TvanProviderCatalog.Get(_settings.TvanProviderName); }
                <MudText Typo="Typo.caption" Class="mt-1 d-block">@selected.Description</MudText>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving">
                @(_saving ? "Đang lưu..." : "Lưu")
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (string.Equals(_settings.TvanProviderName, TvanProviderCatalog.ViettelCode, StringComparison.OrdinalIgnoreCase))
    {
        <MudPaper Class="pa-4 mt-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">Viettel T-VAN</MudText>
                    <MudText Typo="Typo.body2">Tài khoản, endpoint và thông tin mẫu số cho Viettel SInvoice.</MudText>
                    @if (_viettelSettings is not null)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_viettelSettings.IsReadyForSubmission ? Color.Success : Color.Warning)"
                                 Variant="Variant.Outlined" Class="mt-2">
                            @(_viettelSettings.IsReadyForSubmission ? "Sẵn sàng" : "Chưa sẵn sàng")
                        </MudChip>
                    }
                </MudStack>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Settings"
                           OnClick="@(() => Navigation.NavigateTo("/pit/settings/viettel"))">
                    Cài đặt dịch vụ Viettel
                </MudButton>
            </MudStack>
        </MudPaper>
    }
}

@code {
    private SPC.BO.PIT.PitSettings? _settings;
    private SPC.BO.PIT.ViettelSettings? _viettelSettings;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SPC.BO.PIT.PitSettings.GetPitSettingsAsync(ApplicationContext);
        _viettelSettings = await SPC.BO.PIT.ViettelSettings.GetViettelSettingsAsync(ApplicationContext);
    }

    private async Task SaveAsync()
    {
        if (_settings is null) return;
        _saving = true;
        try
        {
            _settings = await _settings.SaveAsync();
            Snackbar.Add("Đã lưu cài đặt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lưu thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
